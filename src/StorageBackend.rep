#include <QVariantList>
#include <QUrl>

class StorageBackend
{
    ENUM StorageStatus {
        Stopped = 0,
        Starting = 1,
        Running = 2,
        Stopping = 3,
        Destroyed = 4
    }

    PROP(QString debugLogs READONLY)
    PROP(StorageStatus status READONLY)
    PROP(int defaultListenPort READONLY)
    PROP(QString defaultConfigJson READONLY)

    // True when the running node was initialised with mix-enabled. Reflects the
    // config the node currently runs with, not the persisted one.
    PROP(bool mixRunning READONLY)

    // Lifecycle
    SLOT(void init(QString configJson))
    SLOT(void start())
    SLOT(void stop())
    SLOT(void destroy())

    // Upload / Download
    SLOT(void uploadFile(QUrl url))
    SLOT(void downloadFile(QString cid, QUrl url, qint64 totalBytes))
    SLOT(void downloadManifest(QString cid))
    SLOT(void downloadManifests())
    SLOT(void exists(QString cid))
    SLOT(void remove(QString cid))
    SLOT(void fetch(QString cid))

    // Space
    SLOT(void refreshSpace())

    // Config
    SLOT(void saveUserConfig(QString configJson))
    SLOT(void saveCurrentConfig())
    SLOT(void loadUserConfig())
    SLOT(QString getUserConfig())
    SLOT(void reloadIfChanged(QString configJson))
    SLOT(QString configJson())

    // Network / Onboarding
    SLOT(void enableUpnpConfig())
    SLOT(void enableNatExtConfig(int tcpPort))
    SLOT(void checkNodeIsUp())
    SLOT(void restartOnboarding())

    // Mix
    // Toggle routing of DHT queries over Mix on the running node. Requires the
    // node to run with mix-enabled and a non-empty dht-mix-proxy, else fails.
    // Returns true on success.
    SLOT(bool togglePrivateQueries(bool enabled))

    // Widgets / Debug
    SLOT(void fetchWidgetsData())
    SLOT(void logDebugInfo())
    SLOT(void logDataDir())
    SLOT(void logVersion())
    SLOT(void logSpr())
    SLOT(void logPeerId())

    // Lifecycle signals
    SIGNAL(initCompleted(bool success, QString error))
    SIGNAL(startCompleted())
    SIGNAL(startFailed(QString error))
    SIGNAL(stopCompleted())

    // Space
    SIGNAL(spaceUpdated(qint64 total, qint64 used))

    // Upload
    SIGNAL(uploadStarted(qint64 totalBytes))
    SIGNAL(uploadChunk(qint64 len))
    SIGNAL(uploadCompleted(QString cid))

    // Download
    SIGNAL(downloadStarted(QString cid, QString filename, qint64 totalBytes))
    SIGNAL(downloadChunk(qint64 len))
    SIGNAL(downloadCompleted(QString cid))

    // Manifests
    SIGNAL(manifestsUpdated(QVariantList manifests))
    SIGNAL(manifestFetchStarted(QString cid))
    SIGNAL(manifestFetchFailed(QString cid, QString error))

    // Remove
    SIGNAL(removeStarted(QString cid))
    SIGNAL(removeFailed(QString cid, QString error))

    // Network / Onboarding
    SIGNAL(onboardingRestarted())
    SIGNAL(natExtConfigCompleted())
    SIGNAL(nodeIsUp())
    SIGNAL(nodeIsntUp(QString reason))
    SIGNAL(peersUpdated(int count))

    // Errors
    SIGNAL(error(QString message))
}
